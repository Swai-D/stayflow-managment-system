{
  "name": "api",
  "version": "1.0.0",
  "private": true,
  "prisma": {
    "schema": "src/prisma/schema.prisma",
    "seed": "ts-node src/prisma/seed.ts"
  },
  "scripts": {
    "dev": "nodemon --watch src --ext ts --exec ts-node src/server.ts",
    "build": "prisma generate && tsc",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "ts-node src/prisma/seed.ts",
    "db:fresh": "prisma db push --force-reset --accept-data-loss && ts-node src/prisma/seed.ts",
    "db:seed:store": "ts-node src/prisma/seed-store.ts",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/client": "5.22.0",
    "@sendgrid/mail": "^8.1.6",
    "@snippe/sdk": "^1.0.0",
    "africastalking": "^0.7.9",
    "axios": "^1.x",
    "bcryptjs": "^2.x",
    "cookie-parser": "^1.4.7",
    "cors": "^2.x",
    "date-fns": "^4.4.0",
    "dotenv": "^16.x",
    "express": "^4.x",
    "helmet": "^7.x",
    "ioredis": "^5.x",
    "jsonwebtoken": "^9.x",
    "morgan": "^1.x",
    "multer": "^1.x",
    "node-cron": "^3.x",
    "prisma": "5.22.0",
    "pdfkit": "^0.16.0",
    "redis": "^4.x",
    "zod": "^3.x"
  },
  "devDependencies": {
    "@types/africastalking": "^0.8.0",
    "@types/bcryptjs": "^2.x",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.x",
    "@types/express": "^4.x",
    "@types/jsonwebtoken": "^9.x",
    "@types/morgan": "^1.x",
    "@types/multer": "^1.x",
    "@types/node": "^20.x",
    "@types/node-cron": "^3.0.11",
    "@types/pdfkit": "^0.13.5",
    "@types/supertest": "^6.x",
    "nodemon": "^3.x",
    "supertest": "^6.x",
    "ts-node": "^10.x",
    "typescript": "^5.x",
    "vitest": "^1.x"
  }
}
